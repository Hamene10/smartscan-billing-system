flowchart TD

    %% External Entities
    Customer((Customer))
    Admin((Admin))
    
    %% Processes (Circles/Rounded rectangles usually, 1 to 4)
    P1("1. Authentication & Users")
    P2("2. Inventory Management")
    P3("3. Scan & Cart Subsystem")
    P4("4. Billing & Checkout")
    
    %% Data Stores (Databases)
    D1[(D1: Users DB)]
    D2[(D2: Products DB)]
    D3[(D3: Orders / Items DB)]
    
    %% ------------ Authentication Process Flows ------------
    Customer -- Credentials --> P1
    Admin -- Credentials --> P1
    P1 -- Read/Write User Data --> D1
    P1 -- Auth Status --> Customer
    P1 -- Auth Status --> Admin
    
    %% ------------ Inventory Process Flows ------------
    Admin -- Add/Edit/Delete Products --> P2
    P2 -- Read/Write Product Data --> D2
    D2 -- Alerts (Stock/Expiry) --> P2
    P2 -- Reports & Alerts --> Admin
    
    %% ------------ Scan & Cart Process Flows ------------
    Customer -- Scan Product Code --> P3
    P3 -- Fetch Product Details --> D2
    D2 -- Returns Price/Stock --> P3
    P3 -- Displays Cart Totals --> Customer
    
    %% ------------ Billing Process Flows ------------
    Customer -- Confirm Order --> P4
    P4 -- Reduce Stock --> D2
    P3 -- Cart Data --> P4
    P4 -- Save Transaction --> D3
    D3 -- Generate Receipt Data --> P4
    P4 -- Provide Final Invoice --> Customer
